# =============================================================================
# b2-credentials.env.example — credenciais do Restic + Backblaze B2.
#
# Copie para `infra/backup/b2-credentials.env` NA VPS e preencha com valores
# REAIS. NÃO commite o arquivo preenchido (só este .example é versionado).
#
# Permissões recomendadas: chmod 600 infra/backup/b2-credentials.env
#
# Os valores abaixo são PLACEHOLDERS — substitua todos.
# =============================================================================

# ---- Repositório Restic no B2 ----
# Formato: b2:<nome-do-bucket>:<caminho/opcional>
RESTIC_REPOSITORY=b2:CHANGEME-bucket-name:backups

# Senha que CRIPTOGRAFA o repositório. Gere com: openssl rand -base64 32
# Guarde fora da VPS também — sem ela, os backups são irrecuperáveis.
RESTIC_PASSWORD=CHANGEME-generate-a-strong-passphrase

# ---- Credenciais da API do Backblaze B2 ----
# Crie uma Application Key dedicada (escopo só do bucket de backup).
B2_ACCOUNT_ID=CHANGEME-keyID
B2_ACCOUNT_KEY=CHANGEME-applicationKey

# ---- Origem do dump (containers) ----
PG_CONTAINER=apps-postgres
PG_SUPERUSER=postgres

# ---- Uploads/volumes a incluir (opcional; vazio = pular) ----
# Aponte pro diretório do host onde ficam uploads persistidos.
UPLOADS_DIR=

# ---- Hook de notificação de erro (opcional) ----
# Recebe a mensagem de erro como argumento. Ex.: curl pro webhook do Slack.
# BACKUP_NOTIFY_CMD=curl -fsS -X POST -d "text=$2" https://hooks.example/CHANGEME
