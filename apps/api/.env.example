# =============================================================================
# apps/api/.env  — copie para apps/api/.env e preencha
#
# Este arquivo é a ÚNICA fonte de envs do backend + da infraestrutura
# (Postgres e Redis). O root do projeto NÃO tem .env — tudo vive aqui.
#
# O deploy.sh carrega este arquivo via `--env-file apps/api/.env` e o
# docker-compose também usa `env_file: ./apps/api/.env` nos serviços.
# =============================================================================

# ---- Node / app ----
NODE_ENV=production
PORT=3333
LOG_LEVEL=info

# ---- Postgres ----
# DATABASE_URL aponta pro host `postgres` (nome do serviço no docker-compose).
# Pra dev local FORA do docker, troque `postgres` por `localhost`.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/template?schema=public

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Auth (better-auth) ----
# Gere com: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-byte-base64
AUTH_BASE_URL=http://localhost:3333
AUTH_TRUSTED_ORIGINS=http://localhost:5173
SECURE_COOKIES=false
# Cookie de sessão. Vazio = host-only (ok p/ dev local e domínio único).
# Quando API e front vivem em SUBDOMÍNIOS do mesmo apex (ex: api.example.com
# e app.example.com), defina o apex com ponto inicial p/ o cookie virar
# first-party nos dois subdomínios em QUALQUER navegador (Safari/iOS, Brave,
# Chrome bloqueando 3rd-party cookies). Sem isso o get-session vem null p/ uns
# navegadores e funciona p/ outros. Exige SECURE_COOKIES=true (HTTPS).
# AUTH_COOKIE_DOMAIN=.example.com

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Rate limit ----
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
# Backstop por IP bruto (pega rotacao de cookie). Atras de BFF/proxy com IP
# compartilhado vira teto GLOBAL de volume — eleve ou repasse o IP real do cliente.
THROTTLE_IP_LIMIT=1000

# ---- Storage ----
# Default: disk (salva em ./uploads). Pra usar S3/R2, mude pra 's3' ou 'r2'
# e preencha bucket/credenciais. Driver 'disk' NÃO precisa de bucket.
STORAGE_DRIVER=disk
# STORAGE_BUCKET=
# STORAGE_REGION=
# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_PUBLIC_URL=

# ---- Mail ----
# Default: desligado (NoopMailProvider — só loga warn). Ative quando precisar
# enviar email de verdade. Com MAIL_ENABLED=true, SMTP_HOST/PORT/FROM são exigidos.
MAIL_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=false

# ---- Webhook (HMAC) ----
# WEBHOOK_SECRET=replace-me

# ---- Bull Board ----
# BULL_BOARD_PATH=/admin/queues

# ---- Portas expostas no host (compose) ----
API_PORT=3333
