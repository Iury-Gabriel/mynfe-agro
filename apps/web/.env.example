# =============================================================================
# apps/web/.env  — copie para apps/web/.env e preencha
#
# Envs do frontend (Vite). São injetadas em BUILD TIME (vite build) — qualquer
# mudança aqui exige rebuild da imagem do web.
#
# O deploy.sh passa estes valores como build args pro Dockerfile do web.
# =============================================================================

# Origin da API (sem /api no fim — o client já prefixa as rotas com /api).
#   - dev: ignorado (o proxy do Vite resolve /api → este target); deixe o localhost.
#   - prod mesmo domínio (reverse proxy serve front + /api): use o origin do front.
#   - prod domínios separados: use o origin da API (ex: https://api.seuapp.com) e
#     configure cookie SameSite=None; Secure + CORS credentials no backend.
VITE_API_BASE_URL=http://localhost:3333

# ---- Porta exposta no host (compose) ----
WEB_PORT=8080
