# =============================================================================
# deploy.env.example — variáveis de DEPLOY (blue-green) na VPS.
#
# Copie para `deploy.env` na raiz do projeto NA VPS e ajuste. Este arquivo NÃO
# substitui apps/api/.env nem apps/web/.env (que continuam sendo a fonte de
# envs da aplicação) — ele só parametriza portas/tags/caminhos do mecanismo de
# blue-green e dos scripts de infra/deploy/.
#
# Os scripts (infra/deploy/*.sh) carregam este arquivo se ele existir; caso
# contrário usam os defaults abaixo. NÃO commite `deploy.env` (só este .example).
# =============================================================================

# ---- Tag/imagem promovida por deploy (a CD seta IMAGE_TAG = tag do git) ----
IMAGE_TAG=latest
# Imagens publicadas pelo CI em GHCR. O workflow também injeta esses valores.
API_IMAGE=ghcr.io/<owner>/boilarplate-api
WEB_IMAGE=ghcr.io/<owner>/boilarplate-web

# ---- Portas host por cor (devem casar com os composes e os nginx confs) ----
BLUE_API_PORT=3341
BLUE_WEB_PORT=8081
GREEN_API_PORT=3342
GREEN_WEB_PORT=8082

# ---- Portas host da infra compartilhada ----
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- nginx do host ----
# Diretório do nginx instalado no host (Debian/Ubuntu padrão).
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
# Symlink que aponta pra cor ativa. switch.sh/rollback.sh manipulam este link.
NGINX_ACTIVE_LINK=/etc/nginx/sites-enabled/active.conf
# Diretório onde blue.conf/green.conf ficam instalados no host.
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available

# ---- Health check ----
# Quantas tentativas e intervalo (s) ao consultar GET /health da cor nova.
POSTGRES_HEALTHCHECK_RETRIES=20
POSTGRES_HEALTHCHECK_INTERVAL=1
POST_SWITCH_HEALTHCHECK_RETRIES=20
POST_SWITCH_HEALTHCHECK_INTERVAL=1
HEALTHCHECK_RETRIES=20
HEALTHCHECK_INTERVAL=1

# ---- Backup pré-deploy condicional ----
# Se existir um snapshot bem-sucedido mais recente que esta janela, o workflow
# de produção pula o backup pré-deploy e segue direto para o deploy.
BACKUP_MAX_AGE_HOURS=24
BACKUP_STATUS_FILE=/tmp/restic-backup.last-success
